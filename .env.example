# Game Recommend API
API_HOST=your-api-host
API_PORT=8000
API_KEY=your-backend-api-key

# Steam
STEAM_API_KEY=your-steam-api-key

# NextAuth
NEXTAUTH_SECRET=your-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# Recommendation Settings Defaults (NEXT_PUBLIC_ = bundled at build time)
NEXT_PUBLIC_DEFAULT_WEIGHT_SIMILARITY=4
NEXT_PUBLIC_DEFAULT_WEIGHT_POPULARITY=3
NEXT_PUBLIC_DEFAULT_WEIGHT_RATING=2
NEXT_PUBLIC_DEFAULT_WEIGHT_RECENCY=1
NEXT_PUBLIC_DEFAULT_HALF_LIFE_DAYS=1825
NEXT_PUBLIC_DEFAULT_MIN_RELEASE_DATE=2000-01-01
NEXT_PUBLIC_DEFAULT_MIN_REVIEW_COUNT=100
NEXT_PUBLIC_DEFAULT_MIN_POSITIVE_PERCENT=50
NEXT_PUBLIC_DEFAULT_RECOMMEND_COUNT=10
NEXT_PUBLIC_CANDIDATE_LIMIT=100
NEXT_PUBLIC_MAX_GAME_SELECTION=20
